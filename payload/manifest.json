{
  "manifest_version": 3,
  "name": "FigBoost",
  "description": "轻量汉化网页版 Figma 的界面文案，不处理画布内容。",
  "version": "1.0.2",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "FigBoost"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.figma.com/*",
    "https://figma.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.figma.com/*",
        "https://figma.com/*"
      ],
      "js": [
        "src/dictionary/zh-CN.js",
        "src/content/localizer-core.js",
        "src/content/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
